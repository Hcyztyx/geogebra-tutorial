{
  "chapters": [
    {
      "title": "第一章：基础入门",
      "icon": "🌱",
      "levels": [
        {
          "title": "创建第一个点",
          "tasks": [
            {
              "title": "创建点 A",
              "instruction": "使用工具栏中的「点」工具，在绘图区点击创建一个点 A",
              "hints": [
                "在左侧工具栏中找到「点」工具（图标是一个小圆点）",
                "点击「点」工具后，在空白区域单击鼠标左键",
                "GeoGebra 会自动将第一个点命名为 A"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "A"
              },
              "points": 10
            },
            {
              "title": "创建点 B(3,4)",
              "instruction": "在输入框中输入 B=(3,4) 创建指定坐标的点",
              "hints": [
                "在底部输入框中输入：B = (3, 4)",
                "注意使用英文括号和逗号",
                "按 Enter 键确认"
              ],
              "validation": {
                "type": "point-coordinates",
                "objectName": "B",
                "expectedX": 3,
                "expectedY": 4,
                "tolerance": 0.1
              },
              "points": 15
            },
            {
              "title": "创建点阵",
              "instruction": "创建三个点：C(1,2)、D(3,2)、E(2,4)",
              "hints": [
                "逐个输入：C = (1, 2)，然后按 Enter",
                "继续输入 D = (3, 2) 和 E = (2, 4)",
                "检查代数区是否显示了所有三个点"
              ],
              "validation": {
                "type": "multiple-points",
                "points": [
                  {"name": "C", "x": 1, "y": 2},
                  {"name": "D", "x": 3, "y": 2},
                  {"name": "E", "x": 2, "y": 4}
                ],
                "tolerance": 0.1
              },
              "points": 20
            }
          ],
          "ggbInitialCommands": []
        },
        {
          "title": "绘制线段",
          "tasks": [
            {
              "title": "创建线段 AB",
              "instruction": "先创建两个点 A 和 B，然后使用「线段」工具连接它们",
              "hints": [
                "先用点工具创建点 A 和 B",
                "在工具栏找到「线段」工具",
                "依次点击点 A 和点 B"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "a"
              },
              "points": 15
            },
            {
              "title": "测量线段长度",
              "instruction": "使用「距离或长度」工具测量线段 AB 的长度",
              "hints": [
                "在工具栏找到「距离或长度」工具",
                "点击线段 AB",
                "长度值会显示在代数区"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "a"
              },
              "points": 10
            }
          ],
          "ggbInitialCommands": ["A=(0,0)", "B=(4,0)"]
        },
        {
          "title": "绘制圆形",
          "tasks": [
            {
              "title": "创建圆",
              "instruction": "使用「圆规」工具，以点 A 为圆心，创建一个圆",
              "hints": [
                "在工具栏找到「圆规」工具",
                "先点击圆心位置",
                "再点击圆周上的一点确定半径"
              ],
              "validation": {
                "type": "circle-exists",
                "objectName": "c"
              },
              "points": 15
            },
            {
              "title": "创建指定半径的圆",
              "instruction": "以原点 O(0,0) 为圆心，创建半径为 3 的圆",
              "hints": [
                "先创建点 O = (0, 0)",
                "使用指令：Circle(O, 3)",
                "或者用圆规工具手动绘制"
              ],
              "validation": {
                "type": "circle-radius",
                "centerName": "c",
                "expectedRadius": 3,
                "tolerance": 0.2
              },
              "points": 20
            }
          ],
          "ggbInitialCommands": []
        },
        {
          "title": "基础工具综合练习",
          "tasks": [
            {
              "title": "绘制三角形",
              "instruction": "创建三个点 A、B、C，然后用线段连接成三角形",
              "hints": [
                "创建三个不共线的点",
                "使用线段工具依次连接 AB、BC、CA",
                "或者使用多边形工具一次性创建"
              ],
              "validation": {
                "type": "multiple-points",
                "points": [
                  {"name": "A", "x": 0, "y": 0},
                  {"name": "B", "x": 4, "y": 0},
                  {"name": "C", "x": 2, "y": 3}
                ],
                "tolerance": 0.5
              },
              "points": 25
            },
            {
              "title": "自由创作",
              "instruction": "使用学过的工具，自由创作一个几何图形",
              "hints": [
                "可以画房子、树、或其他图案",
                "至少使用 3 种不同的工具",
                "发挥你的创意！"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "A"
              },
              "points": 30
            }
          ],
          "ggbInitialCommands": []
        }
      ]
    },
    {
      "title": "第二章：几何构造",
      "icon": "📏",
      "levels": [
        {
          "title": "垂直线与平行线",
          "tasks": [
            {
              "title": "创建垂线",
              "instruction": "创建一条直线，然后过线外一点创建该直线的垂线",
              "hints": [
                "先用直线工具创建直线 a",
                "在直线外创建一点 P",
                "使用「垂线」工具，先选点 P，再选直线 a"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "a"
              },
              "points": 20
            },
            {
              "title": "创建平行线",
              "instruction": "过直线外一点创建该直线的平行线",
              "hints": [
                "使用「平行线」工具",
                "先选线外的点，再选原直线",
                "平行线会自动创建"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "a"
              },
              "points": 20
            }
          ],
          "ggbInitialCommands": ["A=(0,0)", "B=(5,0)", "a=Line(A,B)"]
        },
        {
          "title": "中点与中垂线",
          "tasks": [
            {
              "title": "创建中点",
              "instruction": "创建线段 AB，然后找到它的中点 M",
              "hints": [
                "创建线段 AB",
                "使用「中点或中心」工具",
                "点击线段 AB，中点 M 会自动创建"
              ],
              "validation": {
                "type": "point-coordinates",
                "objectName": "M",
                "expectedX": 2.5,
                "expectedY": 0,
                "tolerance": 0.1
              },
              "points": 20
            },
            {
              "title": "创建中垂线",
              "instruction": "创建线段 AB 的中垂线",
              "hints": [
                "使用「中垂线」工具",
                "点击线段 AB",
                "中垂线会垂直平分线段"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "b"
              },
              "points": 20
            }
          ],
          "ggbInitialCommands": ["A=(0,0)", "B=(5,0)"]
        },
        {
          "title": "角平分线",
          "tasks": [
            {
              "title": "创建角",
              "instruction": "创建三个点 A、B、C，形成角 ABC",
              "hints": [
                "创建三个不共线的点",
                "使用线段工具连接 AB 和 BC",
                "角就形成了"
              ],
              "validation": {
                "type": "multiple-points",
                "points": [
                  {"name": "A", "x": 0, "y": 0},
                  {"name": "B", "x": 3, "y": 0},
                  {"name": "C", "x": 3, "y": 3}
                ],
                "tolerance": 0.5
              },
              "points": 15
            },
            {
              "title": "创建角平分线",
              "instruction": "创建角 ABC 的角平分线",
              "hints": [
                "使用「角平分线」工具",
                "依次点击点 A、B、C（B 是顶点）",
                "角平分线会自动创建"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "b"
              },
              "points": 25
            }
          ],
          "ggbInitialCommands": []
        },
        {
          "title": "三角形构造",
          "tasks": [
            {
              "title": "创建等边三角形",
              "instruction": "使用圆规和直尺构造一个等边三角形",
              "hints": [
                "先画线段 AB 作为底边",
                "分别以 A、B 为圆心，AB 长为半径画圆",
                "两圆交点即为第三个顶点 C"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "A"
              },
              "points": 30
            },
            {
              "title": "三角形的中线",
              "instruction": "创建三角形 ABC 的三条中线",
              "hints": [
                "找到每条边的中点",
                "连接顶点和对边中点",
                "三条中线会交于一点（重心）"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "A"
              },
              "points": 25
            }
          ],
          "ggbInitialCommands": []
        },
        {
          "title": "几何构造综合练习",
          "tasks": [
            {
              "title": "构造正方形",
              "instruction": "使用几何构造工具，创建一个正方形 ABCD",
              "hints": [
                "先画线段 AB",
                "过 A、B 分别作垂线",
                "用圆规确定边长，找到 C、D 点"
              ],
              "validation": {
                "type": "multiple-points",
                "points": [
                  {"name": "A", "x": 0, "y": 0},
                  {"name": "B", "x": 4, "y": 0},
                  {"name": "C", "x": 4, "y": 4},
                  {"name": "D", "x": 0, "y": 4}
                ],
                "tolerance": 0.3
              },
              "points": 35
            }
          ],
          "ggbInitialCommands": []
        }
      ]
    },
    {
      "title": "第三章：函数入门",
      "icon": "📈",
      "levels": [
        {
          "title": "一次函数",
          "tasks": [
            {
              "title": "绘制 y=2x+1",
              "instruction": "在输入框中输入 f(x)=2x+1 绘制一次函数",
              "hints": [
                "在输入框中输入：f(x) = 2x + 1",
                "按 Enter 确认",
                "函数图像会自动绘制"
              ],
              "validation": {
                "type": "function-exists",
                "functionName": "f"
              },
              "points": 20
            },
            {
              "title": "探索斜率",
              "instruction": "创建滑动条 k，绘制函数 y=kx，观察斜率变化",
              "hints": [
                "使用「滑动条」工具创建 k",
                "输入：g(x) = k * x",
                "拖动滑动条观察图像变化"
              ],
              "validation": {
                "type": "function-exists",
                "functionName": "g"
              },
              "points": 25
            }
          ],
          "ggbInitialCommands": []
        },
        {
          "title": "二次函数",
          "tasks": [
            {
              "title": "绘制 y=x²",
              "instruction": "在输入框中输入 h(x)=x^2 绘制二次函数",
              "hints": [
                "在输入框中输入：h(x) = x^2",
                "或者使用：h(x) = x²",
                "抛物线会自动绘制"
              ],
              "validation": {
                "type": "function-exists",
                "functionName": "h"
              },
              "points": 20
            },
            {
              "title": "探索参数",
              "instruction": "创建滑动条 a、b、c，绘制 y=ax²+bx+c",
              "hints": [
                "创建三个滑动条 a、b、c",
                "输入：p(x) = a*x^2 + b*x + c",
                "调整滑动条观察抛物线变化"
              ],
              "validation": {
                "type": "function-exists",
                "functionName": "p"
              },
              "points": 30
            }
          ],
          "ggbInitialCommands": []
        },
        {
          "title": "函数交点",
          "tasks": [
            {
              "title": "求交点",
              "instruction": "绘制 f(x)=x 和 g(x)=x²，找到它们的交点",
              "hints": [
                "分别输入两个函数",
                "使用「交点」工具",
                "点击两条曲线，交点会自动标记"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "A"
              },
              "points": 25
            }
          ],
          "ggbInitialCommands": ["f(x)=x", "g(x)=x^2"]
        },
        {
          "title": "函数综合练习",
          "tasks": [
            {
              "title": "函数图像设计",
              "instruction": "使用多个函数，创作一个有趣的图案",
              "hints": [
                "可以尝试画笑脸、房子等",
                "使用不同颜色的函数",
                "发挥创意！"
              ],
              "validation": {
                "type": "function-exists",
                "functionName": "f"
              },
              "points": 35
            }
          ],
          "ggbInitialCommands": []
        }
      ]
    },
    {
      "title": "第四章：进阶挑战",
      "icon": "🏆",
      "levels": [
        {
          "title": "动态图形",
          "tasks": [
            {
              "title": "旋转的正方形",
              "instruction": "创建一个可以旋转的正方形",
              "hints": [
                "创建滑动条控制角度",
                "使用旋转工具或 Rotate 命令",
                "拖动滑动条观察旋转效果"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "A"
              },
              "points": 35
            }
          ],
          "ggbInitialCommands": []
        },
        {
          "title": "轨迹绘制",
          "tasks": [
            {
              "title": "圆的轨迹",
              "instruction": "创建一个点在圆上运动，绘制其轨迹",
              "hints": [
                "创建一个圆",
                "在圆上创建一点 P",
                "使用轨迹工具或 Locus 命令"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "c"
              },
              "points": 40
            }
          ],
          "ggbInitialCommands": []
        },
        {
          "title": "自由创作",
          "tasks": [
            {
              "title": "创意几何画",
              "instruction": "综合运用所有工具，创作一幅几何艺术作品",
              "hints": [
                "可以画曼陀罗、分形等图案",
                "使用序列命令创建重复图案",
                "分享你的作品！"
              ],
              "validation": {
                "type": "object-exists",
                "objectName": "A"
              },
              "points": 50
            }
          ],
          "ggbInitialCommands": []
        }
      ]
    }
  ]
}
